# =============================================================================
# Triage AI — Production Environment Variables
# Copy to .env and fill in all required values before deploying.
# =============================================================================

# --- Mode ---
# Set to "false" for production. "true" bypasses Stripe/OpenAI requirements.
DEV_MODE=false

# --- OpenAI (REQUIRED) ---
# API key for contract analysis LLM calls.
OPENAI_API_KEY=sk-your-openai-api-key
# Model used for LLM evaluation. gpt-4o-mini is cost-effective for triage.
OPENAI_MODEL=gpt-4o-mini

# --- Stripe (REQUIRED in production) ---
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Database ---
# Set automatically by docker-compose. Override only for external databases.
# DATABASE_URL=postgresql://triage:password@postgres:5432/triage

# --- Redis ---
# Set automatically by docker-compose. Override only for external Redis.
# REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (used by docker-compose) ---
# Strong random password for the database. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_RANDOM_PASSWORD

# --- Security (REQUIRED — change from defaults) ---
# HMAC secret for signing anonymous session tokens. Generate with: openssl rand -hex 32
APP_HMAC_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
# Secret for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
# Set to "true" to mark session cookies as Secure (requires HTTPS).
SECURE_COOKIES=true

# --- Application ---
# Public URL of your deployment (no trailing slash).
BASE_URL=https://your-domain.com

# --- Gunicorn ---
# Number of gunicorn workers. 2 is optimal for a 2 vCPU server.
WEB_WORKERS=2

# --- Stripe Price IDs ---
# Price IDs from https://dashboard.stripe.com/prices for each plan/interval.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
STRIPE_PRICE_UNLIMITED_MONTHLY=
STRIPE_PRICE_UNLIMITED_YEARLY=

# --- Worker (background job processing) ---
# Enable background task processing.
WORKER_ENABLED=true
