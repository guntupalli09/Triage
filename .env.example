# =============================================================
# Triage AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# --- Mode ---
# Set to "true" for local development (skips Stripe/OpenAI requirements)
DEV_MODE=false

# --- Database ---
# PostgreSQL (production)
DATABASE_URL=postgresql://triage:triage_secret@localhost:5432/triage
# SQLite fallback (auto-used if DATABASE_URL is not set)
# DATABASE_URL=sqlite:///data/triage.db

# --- Redis ---
# Required for sessions, rate limiting, and background jobs
REDIS_URL=redis://localhost:6379/0
# For Upstash or TLS Redis:
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST:6379

# --- Background Worker ---
# Set to "true" to enable async job processing (requires Redis + worker process)
WORKER_ENABLED=false

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Security ---
SESSION_SECRET=generate-a-64-char-random-string-here
APP_HMAC_SECRET=generate-another-64-char-random-string-here
SECURE_COOKIES=true

# --- Application ---
BASE_URL=https://triagecounsel.com
ALLOWED_ORIGINS=https://triagecounsel.com,https://www.triagecounsel.com

# --- Logging ---
# "pretty" for colorized terminal output, "json" for structured production logs
LOG_FORMAT=json
LOG_LEVEL=INFO

# --- Gunicorn ---
WEB_WORKERS=4
BIND=0.0.0.0:8000
